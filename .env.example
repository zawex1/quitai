# Supabase (публичные ключи — безопасно для NEXT_PUBLIC_ на клиенте)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Чат: DeepSeek (если есть ключ — сначала он; при 402 или без ключа — GigaChat)
DEEPSEEK_API_KEY=

# --- GigaChat (Сбер) — нужен ОДИН из вариантов ниже ---
# Вариант A: Client ID + Secret из студии https://developers.sber.ru/studio
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

# Вариант B (вместо A): готовый «Ключ авторизации» из кабинета (уже в Base64)
# GIGACHAT_AUTHORIZATION_KEY=

# Необязательно: для ИП/юрлица может понадобиться GIGACHAT_API_CORP (см. документацию Сбера)
# GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Необязательно: модель (по умолчанию GigaChat)
# GIGACHAT_MODEL=GigaChat
